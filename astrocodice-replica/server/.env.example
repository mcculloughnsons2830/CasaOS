# MsFitZ Society — server configuration
#
# The astrology engine works without any key. The AI reading (the heart of the
# app) needs an Anthropic API key. Copy this file to `.env` and fill it in.

# Required for the AI reading + chat. Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Optional — defaults to 8787
PORT=8787
