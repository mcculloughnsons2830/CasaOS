# MsFitZ Society — server configuration
#
# The astrology engine works with no key at all. The AI reading (the heart of the
# app) needs ONE of the two providers below. Copy this file to `.env` and fill in
# whichever you use. Never commit `.env`, and never paste a key into chat.

# --- Option A: OpenRouter (OpenAI-compatible gateway) ---
# Get a key at https://openrouter.ai/keys  (use a FRESH key, not one you've shared)
OPENROUTER_API_KEY=
# Any model id from https://openrouter.ai/models (defaults to a Claude model).
OPENROUTER_MODEL=anthropic/claude-3.7-sonnet

# --- Option B: Anthropic directly ---
# Get a key at https://console.anthropic.com  (uses Claude Opus 4.8 + adaptive thinking)
ANTHROPIC_API_KEY=

# If both are set, OpenRouter is used. Leave the one you don't use blank.

# Optional — defaults to 8787
PORT=8787
